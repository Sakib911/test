echo "🔍 Running pre-push checks..."

# Run TypeScript type checking
echo "📝 Checking TypeScript types..."
npx tsc --noEmit

if [ $? -ne 0 ]; then
  echo "❌ TypeScript type check failed. Please fix the errors before pushing."
  exit 1
fi

# Run ESLint
echo "🔍 Running ESLint..."
npx eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0 --ignore-pattern ".next/**" --ignore-pattern "node_modules/**" --ignore-pattern "out/**" --ignore-pattern "build/**" --ignore-pattern "next-env.d.ts"

if [ $? -ne 0 ]; then
  echo "❌ ESLint check failed. Please fix the errors before pushing."
  exit 1
fi

# Run build check
echo "🏗️  Running build check..."
npm run build

if [ $? -ne 0 ]; then
  echo "❌ Build failed. Please fix the errors before pushing."
  exit 1
fi

echo "✅ All pre-push checks passed!"
